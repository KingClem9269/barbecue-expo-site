                      {
                        "_uid": "90e781f0-aa2f-460e-bf74-f4dd98ee1d16",
                        "color": "white",
                        "component": "AccordionCard",
                        "contentShown": [
                          {
                            "_uid": "12c645c0-1009-40af-9b3a-eae3ca01d757",
                            "color": "primary",
                            "content": "Qu’est-ce que le Salon du Barbecue ?",
                            "heading": "h3",
                            "component": "headline",
                            "textAlign": "start"
                          }
                        ],
                        "contentHidden": [
                          {
                            "_uid": "f43177ee-b9ab-4489-887f-5b4614785915",
                            "bold": false,
                            "color": "primary",
                            "content": "Le Salon du Barbecue est un événement dédié à l’univers du barbecue : matériels, combustibles, accessoires, techniques de cuisson, recettes, dégustations et démonstrations. L’événement existe depuis 2022 et 2026 marquera la 5e édition.",
                            "component": "paragraph",
                            "textAlign": "start"
                          }
                        ]
                      },
                      {
                        "_uid": "6b05ebab-3eab-4360-a32e-3514d306ca87",
                        "color": "white",
                        "component": "AccordionCard",
                        "contentShown": [
                          {
                            "_uid": "cd59153d-60a7-49d8-95c0-7f873afca094",
                            "color": "primary",
                            "content": "Quelles sont les dates et horaires du salon ?",
                            "heading": "h3",
                            "component": "headline",
                            "textAlign": "start"
                          }
                        ],
                        "contentHidden": [
                          {
                            "_uid": "5f997e9b-5a75-4254-a5a7-97199fb9014d",
                            "bold": false,
                            "color": "primary",
                            "content": "Le salon se déroule à Paris du vendredi 10 au dimanche 14 mars :  Vendredi : 9h30 – 19h Samedi : 9h30 – 19h Dimanche : 9h30 – 18h",
                            "component": "paragraph",
                            "textAlign": "start"
                          }
                        ]
                      },
                      {
                        "_uid": "c8a106d6-454c-43b6-b7cc-0e415b1a3cf7",
                        "color": "white",
                        "component": "AccordionCard",
                        "contentShown": [
