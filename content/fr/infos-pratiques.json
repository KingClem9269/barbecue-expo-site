                            "bold": false,
                            "color": "primary",
                            "content": "Le salon a lieu à Paris, au Parc Floral de Paris (12e arrondissement), Hall de la Pinède. Adresse : 26 route du Champ de Manœuvre, 75012 Paris.",
                            "component": "paragraph",
                            "textAlign": "start"
                          }
                        ]
                      },
