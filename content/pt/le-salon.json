                        "_uid": "0f1b3452-6c50-45a5-b2a7-b32142d7110d",
                        "color": "primary",
                        "content": "Barbecue Expo, é o encontro entre uma paixão e uma indústria.",
                        "heading": "hero",
                        "component": "headline",
                        "textAlign": ""
